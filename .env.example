WEDNESDAY_FROG_MASTER_KEY=replace-with-a-32-plus-character-master-key
# WEDNESDAY_FROG_MASTER_KEY_FILE=/data/master.key

WEDNESDAY_FROG_SESSION_SECRET=replace-with-a-32-plus-character-session-secret
# WEDNESDAY_FROG_SESSION_SECRET_FILE=/data/session.key

WEDNESDAY_FROG_SETUP_TOKEN=replace-with-a-32-plus-character-setup-token
# WEDNESDAY_FROG_SETUP_TOKEN_FILE=/data/setup.key

# Optional dual-key rollout support for master-key rotation.
# WEDNESDAY_FROG_PREVIOUS_MASTER_KEY=
# WEDNESDAY_FROG_PREVIOUS_MASTER_KEY_FILE=/data/previous-master.key

WEDNESDAY_FROG_DATABASE_URL=sqlite:////data/wednesday_frog.db
# DATABASE_URL=postgresql+psycopg://wednesday_frog:changeme@postgres:5432/wednesday_frog

# Optional HA scheduler coordination.
# WEDNESDAY_FROG_REDIS_URL=redis://redis:6379/0
# REDIS_URL=redis://redis:6379/0

# HA Compose credentials.
# POSTGRES_USER=wednesday_frog
# POSTGRES_PASSWORD=replace-with-a-postgres-password
# POSTGRES_DB=wednesday_frog

# Optional token-protected metrics endpoint.
# WEDNESDAY_FROG_METRICS_TOKEN=replace-with-a-32-plus-character-metrics-token
# WEDNESDAY_FROG_METRICS_TOKEN_FILE=/data/metrics.key

# Allow private or internal webhook/API hosts only when you mean to.
# WEDNESDAY_FROG_OUTBOUND_ALLOWLIST=chat.internal.example,10.0.0.0/8

WEDNESDAY_FROG_DISABLE_SCHEDULER=false
WEDNESDAY_FROG_SHUTDOWN_GRACE_SECONDS=60
TZ=UTC
